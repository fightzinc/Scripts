# =============================================
# Clean Lab-Proof Notepad++ 64-bit Updater
# =============================================

# Ensure running as Administrator
if (-not ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltinRole] "Administrator")) {
    Write-Host "ERROR: Please run this script as Administrator!" -ForegroundColor Red
    exit
}

# Force TLS 1.2/1.3 for GitHub
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13

# Folder to store installer
$installerFolder = "C:\Temp\Installers"
if (-not (Test-Path $installerFolder)) { New-Item -Path $installerFolder -ItemType Directory | Out-Null }

# Detect existing Notepad++
$npExe = Get-ChildItem "C:\Program Files*" -Recurse -Filter "notepad++.exe" -ErrorAction SilentlyContinue | Select-Object -First 1
if (-not $npExe) { 
    $npExe = Get-ChildItem "C:\Users\$env:USERNAME\AppData\Local\Programs\Notepad++" -Filter "notepad++.exe" -ErrorAction SilentlyContinue | Select-Object -First 1
}

if ($npExe) {
    $installDir = $npExe.DirectoryName
    Write-Host "Detected Notepad++ at: $installDir"

    # Close running Notepad++
    $proc = Get-Process -Name "notepad++" -ErrorAction SilentlyContinue
    if ($proc) {
        Write-Host "Closing running Notepad++..."
        $proc | Stop-Process -Force
        Start-Sleep 2
    }

    # Uninstall silently if possible
    $uninstaller = Join-Path $installDir "uninstall.exe"
    if (Test-Path $uninstaller) {
        Write-Host "Uninstalling existing Notepad++..."
        try {
            Start-Process -FilePath $uninstaller -ArgumentList "/S" -Wait
            Write-Host "Uninstall complete."
            Start-Sleep 2
        } catch {
            Write-Host "WARNING: Failed to uninstall: $_" -ForegroundColor Yellow
        }
    }
} else {
    Write-Host "Notepad++ not found, will perform fresh install."
    $installDir = "C:\Program Files\Notepad++"
}

# Fetch latest 64-bit release info
Write-Host "Fetching latest Notepad++ release info from GitHub..."
try {
    $release = Invoke-RestMethod -Uri "https://api.github.com/repos/notepad-plus-plus/notepad-plus-plus/releases/latest" -UseBasicParsing -ErrorAction Stop
} catch {
    Write-Host "ERROR: Failed to fetch release info: $_" -ForegroundColor Red
    exit
}

# Get 64-bit installer using flexible pattern
$installerAsset = $release.assets |
    Where-Object { $_.name -match "(?i)Installer.*x64.*\.exe$" } |
    Select-Object -First 1

if (-not $installerAsset) {
    Write-Host "ERROR: 64-bit installer not found in release." -ForegroundColor Red
    exit
}

$installerUrl = $installerAsset.browser_download_url
$installerPath = Join-Path $installerFolder $installerAsset.name

# Download installer if missing
if (-not (Test-Path $installerPath)) {
    Write-Host "Downloading Notepad++ 64-bit installer..."
    try {
        Invoke-WebRequest -Uri $installerUrl -OutFile $installerPath -UseBasicParsing -ErrorAction Stop
        Write-Host "Downloaded installer to $installerPath"
    } catch {
        Write-Host "ERROR: Failed to download installer: $_" -ForegroundColor Red
        exit
    }
} else {
    Write-Host "Installer already exists: $installerPath"
}

# Install silently
Write-Host "Installing Notepad++ 64-bit to $installDir..."
try {
    Start-Process -FilePath $installerPath -ArgumentList "/S /D=$installDir" -Wait
    Write-Host "Installation complete."
} catch {
    Write-Host "ERROR: Installation failed: $_" -ForegroundColor Red
    exit
}

# Verify version
try {
    $newVersion = (Get-Item "$installDir\notepad++.exe").VersionInfo.ProductVersion
    Write-Host "Notepad++ version after update: $newVersion" -ForegroundColor Green
} catch {
    Write-Host "WARNING: Could not determine updated version." -ForegroundColor Yellow
}
