[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

Write-Host "=== WinDirStat Installer (Fixed v2.5.0) ===" -ForegroundColor Cyan

try {
    $release = Invoke-RestMethod `
        -Uri "https://api.github.com/repos/windirstat/windirstat/releases/latest" `
        -Headers @{ "User-Agent" = "PowerShell" }

    Write-Host "Version: $($release.tag_name)" -ForegroundColor Green

    # Pick correct installer (priority order)
    $asset = $release.assets | Where-Object { $_.name -eq "WinDirStat-x64.msi" }

    if (-not $asset) {
        $asset = $release.assets | Where-Object { $_.name -eq "WinDirStat-x86.msi" }
    }

    if (-not $asset) {
        throw "No usable MSI installer found."
    }

    $file = "$env:TEMP\$($asset.name)"

    Write-Host "Downloading: $($asset.name)" -ForegroundColor Yellow
    Write-Host $asset.browser_download_url

    Invoke-WebRequest `
        -Uri $asset.browser_download_url `
        -OutFile $file `
        -Headers @{ "User-Agent" = "PowerShell" }

    if (!(Test-Path $file)) {
        throw "Download failed."
    }

    Write-Host "Installing WinDirStat..." -ForegroundColor Cyan

    Start-Process msiexec.exe `
        -ArgumentList "/i `"$file`" /qn /norestart" `
        -Wait

    Write-Host "DONE ✔ WinDirStat installed/updated successfully." -ForegroundColor Green
}
catch {
    Write-Host "FAILED ❌" -ForegroundColor Red
    Write-Host $_.Exception.Message
}
finally {
    if ($file -and (Test-Path $file)) {
        Remove-Item $file -Force
    }
}

Pause
